# ==========================================
# 个股价值投研助手 - 配置文件示例
# 复制此文件为 .env 并填入真实配置
# ==========================================

# ========== API 配置 ==========
# DeepSeek API 配置
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_API_BASE=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Tavily 搜索 API 配置
TAVILY_API_KEY=your_tavily_api_key_here

# ========== 定时任务配置 ==========
# 检查间隔（分钟），默认 180 分钟 = 3 小时
CHECK_INTERVAL_MINUTES=180

# ========== 股票列表配置 ==========
# 关注的个股列表，支持格式：
# - 代码|名称
# - 代码|名称|行业
# - 代码|名称|行业|市值（亿，可选）
STOCK_LIST=601012|隆基绿能|光伏|3000,002407|多氟多|锂电|500,603039|泛微|软件|200,003000|劲仔|食品|100

# ========== 行业列表配置 ==========
# 关注的行业列表，多个行业用逗号或|分隔
INDUSTRY_LIST=光伏行业|玻璃行业|锂电行业|IT软件开发|休闲零食

# ========== 搜索配置 ==========
# 搜索结果数量
SEARCH_RESULT_COUNT=5

# 搜索范围：news, blogs, forums 等，用逗号分隔
SEARCH_SCOPES=news,blogs,forums

# 是否启用论坛搜索（雪球、股吧）
ENABLE_FORUM_SEARCH=true

# ========== 搜索方式配置 ==========
# 搜索提供者：skill（默认使用search-engine skill）或 tavily
SEARCH_PROVIDER=skill

# search-engine skill配置
SEARCH_ENGINE_PATH=../search-engine
SKILL_USE_TARGETED=false
SKILL_USE_MOCK=false

# Tavily搜索配置（使用tavily时生效）
TAVILY_SEARCH_TIME_RANGE_DAYS=2

# ========== 搜索过滤配置 ==========
# 搜索时间范围：60天=2个月
SEARCH_TIME_RANGE_DAYS=60
# 内容最小长度：过滤太短的垃圾内容
SEARCH_MIN_CONTENT_LENGTH=50
# 最大翻页次数
SEARCH_MAX_PAGES=3
# 是否清理模板内容
ENABLE_CONTENT_CLEANUP=true

# ========== 搜索/LLM 超时重试配置 ==========
SEARCH_TIMEOUT=40
SEARCH_MAX_RETRIES=3
LLM_TIMEOUT=90
LLM_MAX_RETRIES=3

# ========== 情绪分析配置 ==========
# 各类型帖子权重
EMOTION_XUEQIU_WEIGHT=0.5
EMOTION_GUBA_HOT_WEIGHT=0.2
EMOTION_GUBA_EXPLOSIVE_WEIGHT=0.2
EMOTION_GUBA_NORMAL_WEIGHT=0.1

# 股吧热度阈值基数（实际阈值 = 市值/100亿 * 基数）
EMOTION_GUBA_HOT_REPLY_BASE=2
EMOTION_GUBA_HOT_LIKE_BASE=2

# 股吧爆值固定阈值
EMOTION_GUBA_EXPLOSIVE_REPLY=10
EMOTION_GUBA_EXPLOSIVE_LIKE=10

# 雪球爆值固定阈值
EMOTION_XUEQIU_EXPLOSIVE_REPLY=100
EMOTION_XUEQIU_EXPLOSIVE_LIKE=100

# 参数动态调整配置
EMOTION_PARAM_UPDATE_DAYS=5
EMOTION_PARAM_CHANGE_THRESHOLD=0.5
EMOTION_PARAM_MIN=1

# 情绪参数保存路径
EMOTION_DATA_FILE=./output/emotion_params.json

# ========== 输出配置 ==========
# 结果保存路径
OUTPUT_DIR=./output

# 日志级别：DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
