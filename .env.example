# ==========================================
# 个股价值投研助手 - 配置文件示例
# 复制此文件为 .env 并填入真实配置
# ==========================================

# ========== API 配置 ==========
# DeepSeek API 配置
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_API_BASE=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Tavily 搜索 API 配置
TAVILY_API_KEY=your_tavily_api_key_here

# ========== 定时任务配置 ==========
# 检查间隔（分钟），默认 180 分钟 = 3 小时
CHECK_INTERVAL_MINUTES=180

# ========== 股票列表配置 ==========
# 关注的个股列表，支持两种格式：
# 格式1: 代码|名称,代码|名称
# 格式2: 代码|名称|行业,代码|名称|行业
STOCK_LIST=601012|隆基绿能,002407|多氟多,603039|泛微,003000|劲仔

# ========== 行业列表配置 ==========
# 关注的行业列表，多个行业用逗号或|分隔
INDUSTRY_LIST=光伏行业|玻璃行业|锂电行业|IT软件开发|休闲零食

# ========== 搜索配置 ==========
# 搜索结果数量
SEARCH_RESULT_COUNT=5

# 搜索范围：news, blogs, forums 等，用逗号分隔
SEARCH_SCOPES=news,blogs,forums

# 是否启用论坛搜索（雪球、股吧）
ENABLE_FORUM_SEARCH=true

# 搜索超时时间（秒）
SEARCH_TIMEOUT=40

# 搜索最大重试次数
SEARCH_MAX_RETRIES=3

# LLM 超时时间（秒）
LLM_TIMEOUT=90

# LLM 最大重试次数
LLM_MAX_RETRIES=2

# ========== 输出配置 ==========
# 结果保存路径
OUTPUT_DIR=./output

# 日志级别：DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
